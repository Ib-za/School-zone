{
  "name": "school-zone",
  "devDependencies": {
    "@types/node": "26.0.1",
    "typescript": "6.0.3"
  },
  "packageManager": "bun@1.3.5",
  "private": true,
  "scripts": {
    "dev:api": "bun --env-file=.env --filter @elate/api dev",
    "dev:web": "bun --env-file=.env --filter @elate/web dev",
    "dev:mobile": "bun --env-file=.env --filter @elate/mobile dev",
    "dev:public-site": "bun --env-file=.env --filter @elate/public-site dev",
    "typecheck": "bun --filter '*' typecheck",
    "install:latest": "bun update --latest"
  },
  "type": "module",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "dependencies": {
    "supabase": "^2.108.0"
  }
}
